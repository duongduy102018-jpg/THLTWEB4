@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="soft-card p-4 p-lg-5">
                <span class="hero-badge">🔑 Tài khoản</span>
                <h1 class="fw-bold mt-3 mb-3">Quên mật khẩu</h1>
                <p class="text-muted">Nhập email để nhận liên kết đặt lại mật khẩu. Trong bản demo, liên kết cũng hiển thị trực tiếp trên màn hình.</p>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-success btn-lg w-100">Gửi liên kết đặt lại</button>
                </form>

                @if (!string.IsNullOrWhiteSpace(Model.DemoResetLink))
                {
                    <div class="alert alert-info mt-4">
                        <strong>Demo reset link:</strong><br />
                        <a href="@Model.DemoResetLink">Bấm vào đây để đặt lại mật khẩu</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
