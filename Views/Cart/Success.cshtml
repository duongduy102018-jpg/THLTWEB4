@model Webbanhang.Models.Order
@{ ViewData["Title"] = "Đặt hàng thành công"; }
<div class="container py-5">
    <div class="success-card mx-auto"><div class="success-icon">✅</div><span class="hero-badge">Hoàn tất đơn hàng</span><h1 class="mt-3">Đặt hàng thành công!</h1><p class="text-muted">Mã đơn hàng của bạn là <strong>#@Model.Id</strong>. HTP Food sẽ liên hệ xác nhận đơn trong thời gian sớm nhất.</p>
        <div class="order-info-grid my-4"><div><span>Khách hàng</span><strong>@Model.CustomerName</strong></div><div><span>Điện thoại</span><strong>@Model.Phone</strong></div><div><span>Tổng tiền</span><strong>@Model.Total.ToString("N0") VNĐ</strong></div></div>
        <div class="soft-card p-3 text-start mb-4"><h5 class="fw-bold">Sản phẩm đã đặt</h5>@foreach (var item in Model.Items){<div class="summary-row"><span>@item.ProductName x @item.Quantity</span><strong>@item.Total.ToString("N0") VNĐ</strong></div>}<hr /><div class="summary-row"><span>Trạng thái</span><strong>@Model.Status</strong></div><div class="summary-row"><span>Thanh toán</span><strong>@Model.PaymentMethod</strong></div></div>
        <div class="d-flex justify-content-center gap-2 flex-wrap"><a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-success px-4">Xem chi tiết đơn</a><a asp-action="Orders" class="btn btn-outline-success px-4">Lịch sử mua hàng</a><a asp-controller="Product" asp-action="Index" class="btn btn-outline-success px-4">Tiếp tục mua</a></div>
    </div>
</div>
