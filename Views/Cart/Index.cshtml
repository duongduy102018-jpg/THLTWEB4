@model Webbanhang.Models.CartSummaryViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<section class="page-hero">
    <div class="container position-relative">
        <span class="hero-badge">🛒 Giỏ hàng</span>
        <h1 class="fw-bold mt-3 display-5">Kiểm tra đơn trước khi thanh toán</h1>
        <p>Điều chỉnh số lượng, áp mã giảm giá và xem phí giao hàng trước khi đặt hàng.</p>
    </div>
</section>

<div class="container py-5">
    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🛒</div>
            <h3>Giỏ hàng đang trống</h3>
            <p>Hãy chọn một vài sản phẩm trái cây tươi cho đơn hàng của bạn.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-success px-4">Xem sản phẩm</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <h3 class="fw-bold mb-0">Sản phẩm đã chọn</h3>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success px-4">Tiếp tục mua</a>
                </div>

                <div class="cart-list">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item enhanced-cart-item">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? Url.Content("~/images/khay-thap-cam.jpg") : item.ImageUrl)" alt="@item.ProductName" />

                            <div class="cart-info">
                                <h5>@item.ProductName</h5>
                                <p>@item.Price.ToString("N0") VNĐ / sản phẩm</p>
                            </div>

                            <form asp-action="UpdateQuantity" method="post" class="quantity-form live-quantity-form">
                                <input type="hidden" name="id" value="@item.ProductId" />
                                <div class="qty-control">
                                    <button type="button" class="qty-btn" data-action="minus">−</button>
                                    <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control qty-input" aria-label="Số lượng @item.ProductName" />
                                    <button type="button" class="qty-btn" data-action="plus">+</button>
                                </div>
                                <small class="text-muted d-block mt-1">Tự cập nhật khi thay đổi</small>
                            </form>

                            <strong class="price">@item.Total.ToString("N0") VNĐ</strong>

                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="id" value="@item.ProductId" />
                                <button class="btn btn-link text-danger fw-bold">Xóa</button>
                            </form>
                        </div>
                    }
                </div>

                @if (Model.RecommendedProducts.Any())
                {
                    <section class="cross-sell mt-5">
                        <div class="section-title mb-3">
                            <div>
                                <span class="hero-badge">Gợi ý thêm</span>
                                <h3 class="fw-bold mt-2">Có thể bạn cũng thích</h3>
                            </div>
                        </div>

                        <div class="row g-3">
                            @foreach (var product in Model.RecommendedProducts)
                            {
                                <div class="col-md-6">
                                    <div class="suggest-card">
                                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? Url.Content("~/images/khay-thap-cam.jpg") : product.ImageUrl)" alt="@product.Name" />
                                        <div>
                                            <h6>@product.Name</h6>
                                            <p>@product.Price.ToString("N0") VNĐ</p>
                                            <form asp-action="AddToCart" method="post">
                                                <input type="hidden" name="id" value="@product.Id" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <button class="btn btn-sm btn-success">Thêm vào giỏ</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>

            <div class="col-lg-4">
                <div class="cart-summary">
                    <h4>Tóm tắt đơn hàng</h4>

                    <form asp-action="ApplyCoupon" method="post" class="coupon-box mb-3">
                        @Html.AntiForgeryToken()
                        <label class="form-label">Mã giảm giá</label>
                        <div class="input-group">
                            <input name="couponCode" value="@Model.CouponCode" class="form-control" placeholder="FRESH10 / COMBO50" />
                            <button class="btn btn-success">Áp dụng</button>
                        </div>
                        <small class="text-muted">FRESH10 giảm 10%, COMBO50 giảm 50.000 VNĐ cho đơn từ 300.000 VNĐ.</small>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.CouponCode))
                    {
                        <form asp-action="RemoveCoupon" method="post" class="mb-3">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger btn-sm">Bỏ mã @Model.CouponCode</button>
                        </form>
                    }

                    <div class="summary-row"><span>Tổng tiền hàng</span><strong>@Model.Subtotal.ToString("N0") VNĐ</strong></div>
                    <div class="summary-row"><span>Phí vận chuyển</span><strong>@(Model.FreeShipping ? "Miễn phí" : Model.ShippingFee.ToString("N0") + " VNĐ")</strong></div>
                    <div class="summary-row"><span>Giảm giá</span><strong>-@Model.Discount.ToString("N0") VNĐ</strong></div>
                    <div class="free-ship-note">Miễn phí giao hàng cho đơn từ 500.000 VNĐ.</div>
                    <hr />
                    <div class="summary-row total"><span>Tổng cần thanh toán</span><strong>@Model.GrandTotal.ToString("N0") VNĐ</strong></div>

                    <a asp-action="Checkout" class="btn btn-success btn-lg w-100 mt-3">Tiến hành thanh toán</a>
                    <form asp-action="Clear" method="post" class="mt-2"><button class="btn btn-outline-danger w-100">Xóa giỏ hàng</button></form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.live-quantity-form').forEach(form => {
            const input = form.querySelector('.qty-input');
            let timer;

            const submitSoon = () => {
                clearTimeout(timer);
                timer = setTimeout(() => form.submit(), 350);
            };

            form.querySelectorAll('.qty-btn').forEach(button => {
                button.addEventListener('click', () => {
                    const current = parseInt(input.value || '0', 10);
                    input.value = button.dataset.action === 'plus'
                        ? current + 1
                        : Math.max(0, current - 1);
                    submitSoon();
                });
            });

            input.addEventListener('change', submitSoon);
        });
    </script>
}
