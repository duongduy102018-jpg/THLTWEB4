@model Webbanhang.Models.Product
@{ ViewData["Title"] = "Thêm sản phẩm"; }
<section class="page-hero"><div class="container position-relative"><span class="hero-badge">🔐 Admin</span><h1 class="fw-bold mt-3 display-5">Thêm sản phẩm mới</h1><p>Nhập thông tin sản phẩm, danh mục, giá bán và ảnh đại diện cho cửa hàng.</p></div></section>
<div class="container py-5"><div class="form-shell"><form asp-action="Add" method="post" enctype="multipart/form-data" class="row g-4">@Html.AntiForgeryToken()<div class="col-lg-8"><div class="soft-card p-4 h-100"><h4 class="fw-bold mb-4">Thông tin sản phẩm</h4><div asp-validation-summary="ModelOnly" class="text-danger"></div><div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control form-control-lg" placeholder="VD: Kiwi vàng New Zealand" /><span asp-validation-for="Name" class="text-danger"></span></div><div class="mb-3"><label asp-for="Price" class="form-label">Giá bán (VNĐ)</label><input asp-for="Price" type="number" class="form-control form-control-lg" placeholder="VD: 189000" /><span asp-validation-for="Price" class="text-danger"></span></div><div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="5" placeholder="Mô tả nguồn gốc, hương vị, cách bảo quản..."></textarea><span asp-validation-for="Description" class="text-danger"></span></div><div class="mb-3"><label asp-for="CategoryId" class="form-label"></label><select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select form-select-lg"><option value="">-- Chọn danh mục --</option></select><span asp-validation-for="CategoryId" class="text-danger"></span></div></div></div><div class="col-lg-4"><div class="soft-card p-4 h-100"><label class="form-label">Hình ảnh sản phẩm</label><input type="file" name="imageFile" id="imageInput" class="form-control" accept="image/*" /><img id="previewImage" src="~/images/khay-thap-cam.jpg" class="preview-img mt-3" alt="Xem trước ảnh" /><div class="d-grid gap-2 mt-4"><button type="submit" class="btn btn-success btn-lg">Lưu sản phẩm</button><a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a></div></div></div></form></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
<script>
    const imageInput = document.getElementById('imageInput');
    const previewImage = document.getElementById('previewImage');
    if (imageInput && previewImage) {
        imageInput.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                previewImage.src = URL.createObjectURL(file);
            }
        });
    }
</script>
}
