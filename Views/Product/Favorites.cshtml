@model List<Webbanhang.Models.Product>
@{ ViewData["Title"] = "Sản phẩm yêu thích"; }
<section class="page-hero"><div class="container position-relative"><span class="hero-badge">❤ Yêu thích</span><h1 class="fw-bold mt-3 display-5">Sản phẩm bạn đã lưu</h1><p>Lưu lại các sản phẩm muốn mua sau, thêm nhanh vào giỏ hàng khi cần.</p></div></section>
<div class="container py-5">
    <div class="d-flex justify-content-end mb-4"><a asp-action="Index" class="btn btn-outline-success px-4">Quay lại sản phẩm</a></div>
    @if (!Model.Any()) { <div class="empty-state"><div class="empty-icon">♡</div><h3>Chưa có sản phẩm yêu thích</h3><p>Bấm biểu tượng trái tim trên sản phẩm để lưu lại.</p><a asp-action="Index" class="btn btn-success px-4">Xem sản phẩm</a></div> }
    else { <div class="row g-4">@foreach (var item in Model){<div class="col-xl-3 col-lg-4 col-md-6"><div class="product-card"><a asp-action="Display" asp-route-id="@item.Id" class="product-img-wrap"><img src="@(string.IsNullOrEmpty(item.ImageUrl) ? Url.Content("~/images/no-image.jpg") : Url.Content(item.ImageUrl))" alt="@item.Name" class="product-img" /><span class="fresh-tag">Đã lưu</span></a><div class="product-card-body"><small>@(item.Category?.Name ?? "Trái cây")</small><h5>@item.Name</h5><p>@(string.IsNullOrWhiteSpace(item.Description) ? "Sản phẩm tươi ngon được chọn lọc mỗi ngày." : item.Description)</p><strong class="price">@item.Price.ToString("N0") VNĐ</strong><div class="d-flex gap-2 mt-3"><form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1"><input type="hidden" name="id" value="@item.Id" /><button class="btn btn-success w-100">Thêm giỏ</button></form><form asp-action="ToggleFavorite" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><button class="btn btn-outline-danger">Bỏ</button></form></div></div></div></div>}</div> }
</div>
