@model Webbanhang.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var role = Context.Session.GetString("HTPFoodRole");
    var isAdmin = User?.IsInRole("Admin") == true || string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="container py-5">
    <div class="product-detail row g-5 align-items-start">
        <div class="col-lg-6"><div class="detail-image-card"><img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? Url.Content("~/images/khay-thap-cam.jpg") : Model.ImageUrl)" alt="@Model.Name" /><span class="fresh-tag">Tươi mới mỗi ngày</span></div></div>
        <div class="col-lg-6">
            <span class="hero-badge">@(Model.Category?.Name ?? "Trái cây")</span>
            <h1 class="fw-bold mt-3 display-5">@Model.Name</h1>
            <div class="detail-price my-3">@Model.Price.ToString("N0") VNĐ</div>
            <p class="detail-description">@(string.IsNullOrWhiteSpace(Model.Description) ? "Sản phẩm được tuyển chọn kỹ, phù hợp dùng hằng ngày, làm quà tặng hoặc đặt cho văn phòng." : Model.Description)</p>
            <div class="detail-benefits my-4"><div>✅ Cam kết đúng hình ảnh và chất lượng</div><div>🚚 Giao nhanh trong ngày, miễn phí từ 500.000 VNĐ</div><div>🔁 Hỗ trợ đổi trả trong 24h nếu sản phẩm không đạt</div><div>🎁 Đóng gói quà tặng theo yêu cầu</div></div>
            @if (!isAdmin)
            {
                <div class="cart-inline-form">
                    <input id="detailQuantity" type="number" value="1" min="1" class="form-control" />
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline-flex"><input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="quantity" value="1" class="quantity-hidden" /><button class="btn btn-success btn-lg px-4">Thêm vào giỏ</button></form>
                    <form asp-controller="Cart" asp-action="BuyNow" method="post" class="d-inline-flex">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><input type="hidden" name="quantity" value="1" class="quantity-hidden" /><button class="btn btn-warning btn-lg px-4">Mua ngay</button></form>
                </div>
                <form asp-action="ToggleFavorite" method="post" class="mt-3">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><button class="btn btn-outline-danger px-4">❤ Thêm/Bỏ yêu thích</button></form>
            }
            <div class="product-policy-grid mt-4"><div><strong>Xuất xứ</strong><span>Chọn lọc theo ngày</span></div><div><strong>Bảo quản</strong><span>2 - 8°C tùy loại</span></div><div><strong>Phù hợp</strong><span>Ăn hằng ngày, quà tặng</span></div></div>
            <div class="d-flex gap-2 mt-4 flex-wrap">@if (isAdmin){<a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-outline-primary px-4">Sửa</a>}<a asp-action="Index" class="btn btn-outline-secondary px-4">Quay lại</a></div>
        </div>
    </div>
</div>
@section Scripts { <script>document.addEventListener('DOMContentLoaded',function(){const q=document.getElementById('detailQuantity');const hs=document.querySelectorAll('.quantity-hidden');function sync(){const v=Math.max(1,parseInt(q.value||'1'));hs.forEach(i=>i.value=v)} if(q){q.addEventListener('input',sync);sync();}});</script> }
