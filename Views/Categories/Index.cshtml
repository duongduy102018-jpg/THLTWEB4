@model IEnumerable<Webbanhang.Models.Category>

@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <span class="hero-badge">🔐 Admin</span>
            <h2 class="fw-bold mt-2">Quản lý danh mục sản phẩm</h2>
            <p class="text-muted">Thêm, sửa, xóa danh mục trái cây trong hệ thống.</p>
        </div>

        <a asp-controller="Categories" asp-action="Add" class="btn btn-success px-4">
            + Thêm danh mục
        </a>
    </div>

    <div class="soft-card p-3">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Mã</th>
                    <th>Tên danh mục</th>
                    <th style="width: 220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td>#@category.Id</td>
                        <td>
                            <strong>@category.Name</strong>
                        </td>
                        <td>
                            <a asp-controller="Categories" asp-action="Update" asp-route-id="@category.Id" class="btn btn-warning btn-sm">
                                Sửa
                            </a>

                            <a asp-controller="Categories" asp-action="Delete" asp-route-id="@category.Id" class="btn btn-danger btn-sm">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>