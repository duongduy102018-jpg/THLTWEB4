@using System.Text.Json
@using Webbanhang.Models
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var cartJson = session?.GetString("HTPFoodCart");
    var favJson = session?.GetString("HTPFoodFavorites");
    var cartItems = string.IsNullOrWhiteSpace(cartJson) ? new List<CartItem>() : JsonSerializer.Deserialize<List<CartItem>>(cartJson) ?? new List<CartItem>();
    var favoriteIds = string.IsNullOrWhiteSpace(favJson) ? new List<int>() : JsonSerializer.Deserialize<List<int>>(favJson) ?? new List<int>();
    var cartCount = cartItems.Sum(x => x.Quantity);
    var favCount = favoriteIds.Count;
    var role = session?.GetString("HTPFoodRole");
    var isAdmin = User?.IsInRole(SD.Role_Admin) == true || string.Equals(role, SD.Role_Admin, StringComparison.OrdinalIgnoreCase);
    var isUser = User?.IsInRole(SD.Role_User) == true || string.Equals(role, SD.Role_User, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HTP Food</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="top-bar">
        <div class="container d-flex flex-wrap justify-content-between gap-2">
            <span>🚚 Giao nhanh trong ngày tại TP.HCM</span>
            <span>Miễn phí vận chuyển từ <strong>500.000 VNĐ</strong></span>
        </div>
    </div>

    <header class="app-header sticky-top">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand brand-logo" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">🍊</span>
                    <span>HTP Food</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0 main-menu">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        @if (!isAdmin)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Favorites">Yêu thích</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Cart" asp-action="Orders">Đơn hàng</a></li>
                        }
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cart" asp-action="Orders">Quản lý đơn</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Categories" asp-action="Index">Danh mục</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="UserManagement" asp-action="Index">Người dùng</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reports" asp-action="Revenue">Doanh thu</a>
                            </li>
                        }
                        @if (!isAdmin)
                        {
                            <a class="icon-link" asp-controller="Product" asp-action="Favorites" title="Yêu thích">❤ <span>@favCount</span></a>
                            <a class="btn btn-outline-success btn-sm-pill" asp-controller="Cart" asp-action="Index">🛒 Giỏ <span class="cart-badge">@cartCount</span></a>
                        }

                        @if (isAdmin)
                        {
                            <span class="role-pill admin">Admin</span>

                            <a class="btn btn-outline-success btn-sm-pill"
                               asp-controller="Categories"
                               asp-action="Index">
                                Danh mục
                            </a>

                            <a class="btn btn-success btn-sm-pill"
                               asp-controller="Product"
                               asp-action="Add">
                                + Sản phẩm
                            </a>
                        }
                        else if (isUser)
                        {
                            <span class="role-pill user">User</span>
                        }

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="page-main" role="main">
        <div class="toast-area container">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success app-alert">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger app-alert">@TempData["Error"]</div>
            }
        </div>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container py-5">
            <div class="row g-4">
                <div class="col-lg-5">
                    <div class="footer-brand"><span>🍊</span><strong>HTP Food</strong></div>
                    <p class="mt-3 mb-0">Website bán trái cây tươi, hỗ trợ giỏ hàng, đặt hàng, phân quyền người dùng và quản trị hệ thống.</p>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6>Cửa hàng</h6>
                    <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                    <a asp-controller="Product" asp-action="Index">Sản phẩm</a>
                    <a asp-controller="Cart" asp-action="Index">Giỏ hàng</a>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6>Quản lý</h6>
                    <a asp-controller="Cart" asp-action="Orders">Đơn hàng</a>
                    <a asp-controller="Profile" asp-action="Index">Hồ sơ</a>
                    <a asp-controller="Home" asp-action="Contact">Liên hệ</a>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h6>Liên hệ</h6>
                    <p class="mb-1">475A Điện Biên Phủ, TP.HCM</p>
                    <p class="mb-1">0909 000 000</p>
                    <p class="mb-0">support@htpfood.vn</p>
                </div>
            </div>
        </div>
        <div class="footer-bottom text-center py-3">© 2026 HTP Food. All rights reserved.</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
